---
import Time from "./Time.astro";

interface Props {
  company: string;
  id: string;
  roles: Array<{
    period: {
      end?: string;
      start: string;
    };
    position: string;
  }>;
}

const { company, id, roles } = Astro.props;
---

<h3 id={id}>{company}</h3>
<p>
  {
    roles &&
      roles.map(({ period, position }) => (
        <>
          <span class="font-medium">{position}</span>,
          <span class="text-nowrap text-sm">
            <Time isoString={period.start} />
            to
            {period.end ? <Time isoString={period.end} /> : "Present"}
            <br />
          </span>
        </>
      ))
  }
</p>

<slot />
