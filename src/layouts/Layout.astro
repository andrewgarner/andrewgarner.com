---
import { Font } from "astro:assets";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="Andrew Garner is a technical practitioner based in London." name="description" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content="yes" name="apple-mobile-web-app-capable" />
    <meta content="black-translucent" name="apple-mobile-web-app-status-bar-style" />
    <title>{title}</title>
    <link href="https://www.andrewgarner.com/" rel="canonical" />
    <Font cssVariable="--font-sometype-mono" preload />
  </head>
  <body class="bg-stone-50 px-8 pt-16 sm:pt-32 dark:bg-stone-800">
    <div
      class="prose prose-stone mx-auto text-pretty font-mono tracking-tight subpixel-antialiased [font-kerning:normal] dark:prose-invert prose-headings:font-normal prose-a:font-normal prose-a:decoration-stone-400 prose-a:underline-offset-2 hover:prose-a:decoration-stone-900 prose-li:marker:text-stone-400 dark:prose-a:text-stone-300 dark:prose-a:decoration-stone-400 dark:hover:prose-a:decoration-current"
    >
      <header>
        <h1>Andrew Garner</h1>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p class="mb-8 mt-16 text-sm sm:mb-32">Copyright © Andrew Garner.</p>
      </footer>
    </div>
  </body>
</html>
